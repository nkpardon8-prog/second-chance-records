# Environment variables required by Second Chance Records.
# Copy to `.env.local` for development. Never commit real values.

# --- Database (Neon Postgres) ---
# Primary connection string. Used by Drizzle / @neondatabase/serverless.
DATABASE_URL=

# --- Auth (iron-session) ---
# Cookie encryption secret. MUST be at least 32 characters. Generate with:
#   openssl rand -hex 32
SESSION_SECRET=

# --- Site URL ---
# Public origin used to emit + validate /api/images/* URLs. No trailing slash.
# Example: https://secondchancerecords.com
NEXT_PUBLIC_SITE_URL=

# --- Instagram sync (Apify) ---
# Optional. Required only by the Apify-backed Instagram sync flow.
APIFY_API_TOKEN=

# --- Event discovery (Perplexity) ---
# Optional. Required only by the Discover Events admin tool.
PERPLEXITY_API_KEY=

# --- Analytics (Google Analytics) ---
# Optional. If set, GA tag fires on the public site.
NEXT_PUBLIC_GA_ID=
